# Problem: Maximum Subarray
# Time Complexity: O(n)

def maxsub(nums):

    curr = nums[0]
    maxi = nums[0]

    for i in range(1, len(nums)):

        curr = max(nums[i], curr + nums[i])

        maxi = max(maxi, curr)

    return maxi


nums = list(map(int, input("enter numbers: ").split()))

print(maxsub(nums))
